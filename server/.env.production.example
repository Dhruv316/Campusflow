# ── Database ──────────────────────────────────────────────────────────────
# Railway PostgreSQL connection string — copy from Railway dashboard > Variables
DATABASE_URL=postgresql://postgres:password@containers-us-west-xxx.railway.app:5432/railway

# ── JWT Secrets ───────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-64-char-random-hex-string-access
JWT_REFRESH_SECRET=replace-with-64-char-random-hex-string-refresh

# JWT expiry
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Server ─────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── CORS ───────────────────────────────────────────────────────────────────
# Your Vercel deployment URL (no trailing slash)
CLIENT_URL=https://your-app.vercel.app

# ── Email (SMTP) ───────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-production-email@gmail.com
# Use a Gmail App Password — NOT your account password
# Create at: myaccount.google.com/apppasswords
SMTP_PASS=your-gmail-app-password
EMAIL_FROM=noreply@campusflow.app
